{
  "name": "@reference-ui/pipeline",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsx src/cli.ts build",
    "test:pipeline": "pnpm exec tsx --test",
    "test:matrix": "pnpm exec tsx src/cli.ts test --full",
    "setup:matrix": "pnpm exec tsx src/cli.ts setup",
    "registry:pack": "pnpm exec tsx src/cli.ts registry pack",
    "registry:load:local": "pnpm exec tsx src/cli.ts registry load --registry http://127.0.0.1:4873",
    "registry:start": "pnpm exec verdaccio --config ./src/registry/verdaccio/config.yaml --listen 127.0.0.1:4873",
    "setup:local": "bash ./setup/local.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@dagger.io/dagger": "^0.20.6",
    "commander": "^14.0.3",
    "liquidjs": "^10.24.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "verdaccio": "^6.1.6"
  }
}