{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": false,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@reference-ui/core": ["packages/reference-core/src/public.ts"],
      "@reference-ui/core/config": ["packages/reference-core/src/config/index.ts"],
      "@reference-ui/core/constants": ["packages/reference-core/src/constants.ts"],
      "@reference-ui/cli": ["packages/reference-core/src/public.ts"],
      "@reference-ui/cli/config": ["packages/reference-core/src/config/index.ts"],
      "@reference-ui/gen": ["packages/reference-gen/src/index.ts"],
      "@reference-ui/icons": ["packages/reference-icons/src/index.ts"],
      "@reference-ui/lib": ["packages/reference-lib/src/index.ts"],
      "@reference-ui/lib/theme": ["packages/reference-lib/src/core/theme/index.ts"],
      "@fixtures/extend-library": ["fixtures/extend-library/src/index.ts"],
      "@fixtures/extend-library-2": ["fixtures/extend-library-2/src/index.ts"],
      "@fixtures/meta-extend-library": ["fixtures/meta-extend-library/src/index.ts"],
      "@fixtures/meta-extend-library-2": ["fixtures/meta-extend-library-2/src/index.ts"],
      "@fixtures/meta-extend-library-sibling": ["fixtures/meta-extend-library-sibling/src/index.ts"],
      "@fixtures/layer-library": ["fixtures/layer-library/src/index.ts"],
      "@fixtures/layer-library-2": ["fixtures/layer-library-2/src/index.ts"],
      "@fixtures/demo-ui": ["fixtures/demo-ui/src/index.ts"],
      "@fixtures/atlas-project": ["fixtures/atlas-project/src"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
