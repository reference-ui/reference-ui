{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true,
    "declaration": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@reference-ui/system": ["./.reference-ui/system"],
      "@reference-ui/system/baseSystem": ["./.reference-ui/system/baseSystem.d.mts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "ui.config.ts"],
  "exclude": ["dist", "node_modules"]
}
