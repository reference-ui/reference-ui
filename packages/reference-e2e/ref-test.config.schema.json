{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "defaultProject": { "type": "string", "description": "Project for test:quick and test:ui" },
    "basePort": { "type": "number", "description": "Base port; each matrix entry gets basePort + index" },
    "workers": { "type": "number", "description": "Playwright workers per project" },
    "parallelSandboxes": { "type": "boolean", "description": "Run matrix projects in parallel (REF_TEST_PARALLEL)" }
  }
}
