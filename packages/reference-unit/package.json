{
  "name": "@reference-ui/reference-unit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:fixture": "pnpm --filter @fixtures/extend-library run build",
    "dev": "pnpm run build:fixture && ref sync && (ref sync --watch & vite)",
    "build": "pnpm run build:fixture && ref sync && vite build",
    "preview": "vite preview",
    "test": "pnpm run test:vitest && tsc --noEmit",
    "test:vitest": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fixtures/extend-library": "workspace:*",
    "@reference-ui/core": "workspace:*",
    "@reference-ui/lib": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@reference-ui/rust": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "happy-dom": "^15.0.0",
    "typescript": "~5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
