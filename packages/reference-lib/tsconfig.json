{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@reference-ui/icons": ["../reference-icons/dist/index.d.ts"],
      "@reference-ui/react": ["./.reference-ui/react"],
      "@reference-ui/react/styles.css": ["./.reference-ui/react/styles.css"],
      "@reference-ui/styled": ["./.reference-ui/styled"],
      "@reference-ui/styled/jsx": ["./.reference-ui/styled/jsx/index"],
      "@reference-ui/styled/*": ["./.reference-ui/styled/*"],
      "@reference-ui/system": ["./.reference-ui/system"],
      "@reference-ui/system/baseSystem": ["./.reference-ui/system/baseSystem.mjs"],
      "@reference-ui/types": ["./.reference-ui/types"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.jsx"]
}
