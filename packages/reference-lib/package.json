{
  "name": "@reference-ui/lib",
  "version": "0.0.33",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/reference-ui/reference-ui",
    "directory": "packages/reference-lib"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.mjs"
    }
  },
  "files": [
    "dist",
    ".reference-ui/system/baseSystem.d.mts",
    ".reference-ui/system/baseSystem.mjs",
    "README.md"
  ],
  "scripts": {
    "build:deps": "node ../../scripts/pipeline/run-if-env-absent.mjs REF_PIPELINE_SKIP_DEPENDENCY_BUILDS \"pnpm --filter @reference-ui/core run build && pnpm --filter @reference-ui/icons run build\"",
    "sync": "ref sync",
    "typecheck": "pnpm run build:deps && pnpm run sync && tsc --noEmit",
    "build": "pnpm run build:deps && pnpm run sync && tsup && node scripts/build-package.mjs",
    "dev": "ref sync --watch",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "cosmos": "cosmos",
    "cosmos-export": "cosmos-export"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@reference-ui/core": "workspace:*",
    "@reference-ui/icons": "0.0.30",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "react-cosmos": "^7.2.0",
    "react-cosmos-plugin-vite": "^7.2.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
