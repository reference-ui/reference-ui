{
  "name": "@reference-ui/reference-test",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/reference-test/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "quick": {
      "dependsOn": ["reference-core:build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "REF_TEST_FRESH=1 pnpm run test:quick",
        "cwd": "packages/reference-test"
      }
    },
    "test": {
      "dependsOn": ["reference-core:build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm test",
        "cwd": "packages/reference-test"
      }
    }
  }
}
