{
  "compilerOptions": {
    "rootDir": "src",
    "jsx": "react-jsx",
    "outDir": null,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "lib": ["es2020", "es2022"],
    "resolveJsonModule": true,
    "paths": {
      "@reference-ui/react": ["./src/entry/react.ts"],
      "@reference-ui/styled": ["./src/system/styled"],
      "@reference-ui/styled/jsx": ["./src/system/styled/jsx/index"],
      "@reference-ui/styled/*": ["./src/system/styled/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "src/system/styled"]
}
