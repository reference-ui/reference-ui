{
  "name": "@reference-ui/core",
  "version": "0.0.1",
  "private": false,
  "description": "Reference UI core",
  "type": "module",
  "bin": {
    "ref": "./bin/ref.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/public.ts",
      "import": "./dist/cli/public.mjs"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/cli/config.mjs"
    }
  },
  "scripts": {
    "prebuild": "tsx src/system/build/primitives/index.ts && tsx src/system/build/styled/index.ts",
    "build": "pnpm run build:native && tsup",
    "build:native": "pnpm --filter @reference-ui/reference-rs run build",
    "prepack": "pnpm run build",
    "dev": "tsup --watch",
    "sync": "node dist/cli/index.mjs sync",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && vitest run",
    "test:watch": "vitest",
    "eslint:txt": "eslint . --format stylish --color"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pandacss/dev": "^1.8.2",
    "@pandacss/node": "^1.8.2",
    "@pandacss/types": "^1.8.2",
    "@parcel/watcher": "^2.5.6",
    "@reference-ui/reference-rs": "workspace:*",
    "@rspress/mdx-rs": "^0.6.6",
    "commander": "^14.0.3",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.2",
    "liquidjs": "^10.24.0",
    "picocolors": "^1.1.0",
    "picomatch": "^4.0.0",
    "piscina": "^5.1.4",
    "symlink-dir": "^9.0.0",
    "tsup": "^8.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-sonarjs": "^4.0.0",
    "react": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
