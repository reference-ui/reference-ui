{
  "name": "@reference-ui/core",
  "version": "0.0.13",
  "private": false,
  "description": "Reference UI core",
  "repository": {
    "type": "git",
    "url": "https://github.com/reference-ui/reference-ui",
    "directory": "packages/reference-core"
  },
  "type": "module",
  "bin": {
    "ref": "./bin/ref.mjs",
    "mcp": "./bin/mcp.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "tools/copy-reference-api-component.mjs"
  ],
  "exports": {
    ".": {
      "types": "./src/public.ts",
      "import": "./dist/cli/public.mjs"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/cli/config.mjs"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./dist/cli/constants.mjs"
    }
  },
  "scripts": {
    "copy:reference-api-component": "node tools/copy-reference-api-component.mjs",
    "prebuild": "tsx src/system/build/primitives/index.ts && tsx src/system/build/styled/index.ts && pnpm run copy:reference-api-component",
    "build": "pnpm run build:native && tsup",
    "build:native": "pnpm --filter @reference-ui/rust run build",
    "prepack": "pnpm run build",
    "predev": "pnpm run copy:reference-api-component",
    "dev": "tsup --watch",
    "sync": "node dist/cli/index.mjs sync",
    "pretypecheck": "pnpm run copy:reference-api-component",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && vitest run",
    "test:watch": "vitest",
    "eslint:txt": "eslint . --format stylish --color"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": "^5.2.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pandacss/dev": "^1.9.0",
    "@pandacss/node": "^1.9.0",
    "@pandacss/types": "^1.9.0",
    "@parcel/watcher": "^2.5.6",
    "@reference-ui/rust": "workspace:*",
    "@rspress/mdx-rs": "^0.6.6",
    "commander": "^14.0.3",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.2",
    "liquidjs": "^10.24.0",
    "picocolors": "^1.1.0",
    "picomatch": "^4.0.0",
    "piscina": "^5.1.4",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "symlink-dir": "^9.0.0",
    "tsdown": "^0.21.5",
    "tsup": "^8.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-sonarjs": "^4.0.0",
    "react": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
