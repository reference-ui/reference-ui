{
  "name": "@reference-ui/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Reference UI CLI",
  "type": "module",
  "bin": {
    "ref": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": "./dist/cli/index.mjs",
    "./config": "./dist/cli/config.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "sync": "node dist/cli/index.mjs sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "eslint:txt": "eslint . --format stylish --output-file .eslint-result.txt --no-color || true"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "commander": "^14.0.3",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.0",
    "picomatch": "^4.0.0",
    "piscina": "^5.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-sonarjs": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
