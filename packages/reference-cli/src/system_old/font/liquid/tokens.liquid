{% comment %}
  Font tokens — fonts + fontWeights
  Rendered by system/font/render.ts
{% endcomment %}
tokens({
  fonts: {
    {% for font in fonts %}
    {{ font.name }}: { value: {{ font.value | json }} },
    {% endfor %}
  },
  fontWeights: {
    {% for font in fonts %}
      {% if font.weights %}
        {% for weight in font.weights %}
    '{{ font.name }}.{{ weight[0] }}': { value: '{{ weight[1] }}' },
        {% endfor %}
      {% endif %}
    {% endfor %}
  },
})
