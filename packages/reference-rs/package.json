{
  "name": "@reference-ui/rust",
  "version": "0.0.3",
  "private": false,
  "description": "Reference UI Rust and native bindings",
  "repository": {
    "type": "git",
    "url": "https://github.com/reference-ui/reference-ui",
    "directory": "packages/reference-rs"
  },
  "type": "module",
  "napi": {
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ],
    "binaryName": "virtual-native"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "*.node",
    "README.md",
    "npm"
  ],
  "scripts": {
    "artifacts": "pnpm exec napi artifacts --output-dir artifacts",
    "build": "pnpm run ensure-native && pnpm run build:js",
    "build:js": "tsup",
    "build:native": "pnpm exec napi build --platform --release",
    "create-npm-dirs": "pnpm exec napi create-npm-dirs",
    "ensure-native": "pnpm exec tsx ./js/tools/ensure-native.ts",
    "prepack": "pnpm run build:js",
    "prepublish:npm": "pnpm exec napi prepublish --no-gh-release -t npm",
    "publish:native": "pnpm exec tsx ./js/tools/publish-native.ts",
    "stage-local-artifacts": "pnpm exec tsx ./js/tools/stage-local-artifacts.ts",
    "test": "vitest run",
    "test:rust": "cargo test",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
